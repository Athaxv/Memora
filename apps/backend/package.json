{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "bun run build && bun run start:prod",
    "start:prod": "sh scripts/run-built.sh",
    "start:deploy": "bun run build && bun run start:prod",
    "check-types": "tsc --noEmit",
    "backfill:embeddings": "tsx src/scripts/backfill-embeddings.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@repo/ai": "*",
    "@repo/db": "*",
    "@repo/graph": "*",
    "@repo/ingestion": "*",
    "@repo/memory": "*",
    "@repo/validators": "*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "openai": "^4.80.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
